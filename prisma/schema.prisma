generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Application {
  id          String   @id @default(cuid())
  companyName String
  jobTitle    String
  status      String
  dateApplied String?
  salary      String?
  location    String
  jobUrl      String?
  nextStep    String?
  createdAt   DateTime @default(now())
}
